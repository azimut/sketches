%!PS-Adobe-3.0
%%BoundingBox: 0 0 400 400

% Based on Tsoding video
% Problem:
% - obj coordinates are in world space
% - so no rotation is possible outsize rotate_z

/width  400 def
/height 400 def
/s 4 def

% [ r g b ] --
/setcolor {
  { 255 div } forall setrgbcolor
} def

% a b -- c
/safediv {
  dup 0 eq { 0 } { div } ifelse
} def

% x y s --
/point {
  /y exch def /x exch def
  x s 2 div sub
  y s 2 div sub
  s s
  rectfill
} def

% x y -- x' y'
/screen {
  /y exch def /x exch def
  x 1 add 2 div width  mul
  y 1 add 2 div height mul
} def

% x y z -- x' y'
/project {
  /z exch def /y exch def /x exch def
  x z safediv
  y z safediv
} def

/rotate_x { % weird
  /angle exch def /z exch def /y exch def /x exch def
  x
  y angle cos mul z angle sin mul sub
  y angle sin mul z angle cos mul add
} def

/rotate_y { % weird
  /angle exch def /z exch def /y exch def /x exch def
  z angle sin mul x angle cos mul add
  y
  z angle cos mul x angle sin mul sub
} def

/rotate_z { % ok
  /angle exch def /z exch def /y exch def /x exch def
  x angle cos mul y angle sin mul sub
  x angle sin mul y angle cos mul add
  z
} def

[ 44 44 100 ] setcolor

% TODO: take [ x y z ] instead of x y z

 0.5  0.5 2 40 rotate_z project screen point
-0.5  0.5 2 40 rotate_z project screen point
 0.5 -0.5 2 40 rotate_z project screen point
-0.5 -0.5 2 40 rotate_z project screen point
 0.5  0.5 1 40 rotate_z project screen point
-0.5  0.5 1 40 rotate_z project screen point
 0.5 -0.5 1 40 rotate_z project screen point
-0.5 -0.5 1 40 rotate_z project screen point

[ 200 4 4 ] setcolor
0 0 screen point
